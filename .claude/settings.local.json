{
  "permissions": {
    "additionalDirectories": [
      "..\\vscode"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -E '\\.(ts|tsx|js|jsx)$' | xargs -d '\\n' -r pnpm exec eslint --fix",
            "statusMessage": "ESLint fix..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/save-plan-result.cjs"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Explore",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/save-explore-result.cjs"
          }
        ]
      }
    ]
  }
}
