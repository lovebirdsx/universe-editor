{
  "name": "@acme/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "clean": "tsc --build --clean"
  },
  "dependencies": {
    "@acme/shared": "workspace:*",
    "@hono/node-server": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@acme/config-eslint": "workspace:*",
    "@acme/config-ts": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
