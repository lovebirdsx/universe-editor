{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@universe-editor/config-ts/node",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "outDir": "dist/types/node",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo-node",
    "types": ["node", "electron-vite/node"],
    "lib": ["ES2022"]
  },
  "include": ["src/main", "src/preload", "src/shared"],
  "references": [
    { "path": "../../packages/platform" }
  ]
}
