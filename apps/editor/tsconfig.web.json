{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@universe-editor/config-ts/react",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist/types/web",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo-web",
    "types": ["vite/client"]
  },
  "include": ["src/renderer", "src/shared"],
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/platform" }
  ]
}
