{
  "name": "universe-excel-diff",
  "displayName": "Excel Viewer & Diff",
  "description": "Preview Excel/CSV spreadsheets inside the editor and diff two versions cell-by-cell (SheetJS). Works with the Explorer compare commands and with Git / Perforce version comparison.",
  "version": "0.1.0",
  "publisher": "universe",
  "license": "Apache-2.0",
  "type": "module",
  "icon": "icon.png",
  "categories": ["Content Tools"],
  "keywords": ["excel", "xlsx", "csv", "spreadsheet", "diff", "compare", "custom editor"],
  "main": "dist/extension.js",
  "engines": {
    "universe": ">=0.4.0 <1.0.0"
  },
  "files": ["dist", "assets", "icon.png"],
  "activationEvents": ["onCustomEditor:universe.excel"],
  "contributes": {
    "customEditors": [
      {
        "viewType": "universe.excel",
        "displayName": "Excel Viewer",
        "selector": [
          { "filenamePattern": "*.xlsx" },
          { "filenamePattern": "*.xls" },
          { "filenamePattern": "*.xlsm" },
          { "filenamePattern": "*.csv" }
        ],
        "priority": "default",
        "supportsDiff": true
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "node ../../extensions/numbered-bookmarks/node_modules/typescript/bin/tsc --noEmit",
    "e2e": "node ../../scripts/e2e/run-external-e2e.mjs",
    "e2ea": "node ../../scripts/e2e/run-external-e2e.mjs --regression",
    "e2eg": "node ../../scripts/e2e/run-external-e2e.mjs --no-tag-filter --grep",
    "package": "node esbuild.config.mjs && node scripts/pack.mjs"
  },
  "dependencies": {
    "xlsx": "0.18.5"
  }
}
