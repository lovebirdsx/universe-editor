{
  "name": "universe-editor-mcp-bridge",
  "displayName": "Universe Editor MCP Bridge",
  "description": "Registers the Universe Editor MCP bridge for Agent sessions.",
  "version": "0.1.0",
  "publisher": "universe",
  "license": "Apache-2.0",
  "type": "module",
  "icon": "icon.png",
  "main": "dist/extension.js",
  "engines": {
    "universe": ">=0.6.0 <1.0.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "该扩展会向 Agent 会话注入 MCP server（可执行编辑器侧工具），因此需要信任工作区。"
    }
  },
  "files": ["dist", "resources", "icon.png"],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "universeEditorMcp.reconnect",
        "title": "Universe Editor MCP: Reconnect",
        "category": "Universe Editor MCP",
        "icon": "plug"
      }
    ],
    "configuration": {
      "title": "Universe Editor MCP",
      "properties": {
        "universeEditorMcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically register the Universe Editor MCP bridge in Agent MCP server settings when a UE4Editor.exe process is found."
        },
        "universeEditorMcp.timeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "description": "How long the bridge waits for a tool response from Universe Editor before timing out, in milliseconds."
        },
        "universeEditorMcp.connectTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "How long the bridge waits to connect to the Universe Editor named pipe before timing out, in milliseconds."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "node ../../node_modules/@typescript/native-preview/bin/tsgo --noEmit",
    "lint": "node ../../extensions/typescript/node_modules/eslint/bin/eslint.js src",
    "lint:fix": "node ../../extensions/typescript/node_modules/eslint/bin/eslint.js --fix src",
    "package": "node esbuild.config.mjs && node scripts/pack.mjs",
    "icon": "node scripts/rasterize-icon.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true});require('node:fs').rmSync('resources',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.4",
    "zod": "4.4.3"
  }
}
