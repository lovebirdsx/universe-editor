{
  "name": "@universe-editor/git",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "displayName": "Git",
  "description": "Git source control integration (first-party Universe extension).",
  "main": "dist/extension.js",
  "engines": {
    "universe": "^0.1.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      { "command": "git.commit", "title": "Commit", "category": "Git", "icon": "git-commit" },
      { "command": "git.commitAndPush", "title": "Commit & Push", "category": "Git", "icon": "push" },
      { "command": "git.commitAndSync", "title": "Commit & Sync", "category": "Git", "icon": "sync" },
      { "command": "git.undoLastCommit", "title": "Undo Last Commit", "category": "Git", "icon": "discard" },
      { "command": "git.refresh", "title": "Refresh", "category": "Git", "icon": "refresh" },
      { "command": "git.stage", "title": "Stage Changes", "category": "Git", "icon": "add" },
      { "command": "git.unstage", "title": "Unstage Changes", "category": "Git", "icon": "remove" },
      { "command": "git.stageAll", "title": "Stage All Changes", "category": "Git", "icon": "stage-all" },
      { "command": "git.unstageAll", "title": "Unstage All Changes", "category": "Git", "icon": "unstage-all" },
      { "command": "git.discard", "title": "Discard Changes", "category": "Git", "icon": "discard" },
      { "command": "git.discardAll", "title": "Discard All Changes", "category": "Git", "icon": "discard-all" },
      { "command": "git.checkout", "title": "Checkout to...", "category": "Git", "icon": "checkout" },
      { "command": "git.createBranch", "title": "Create Branch...", "category": "Git", "icon": "create-branch" },
      { "command": "git.renameBranch", "title": "Rename Branch...", "category": "Git", "icon": "checkout" },
      { "command": "git.deleteBranch", "title": "Delete Branch...", "category": "Git", "icon": "remove" },
      { "command": "git.merge", "title": "Merge Branch...", "category": "Git", "icon": "merge" },
      { "command": "git.rebase", "title": "Rebase Branch...", "category": "Git", "icon": "merge" },
      { "command": "git.publishBranch", "title": "Publish Branch", "category": "Git", "icon": "push" },
      { "command": "git.createWorktree", "title": "Create Worktree...", "category": "Git", "icon": "new-folder" },
      { "command": "git.openWorktree", "title": "Open Worktree", "category": "Git", "icon": "git-worktree" },
      { "command": "git.openWorktreeInNewWindow", "title": "Open Worktree in New Window", "category": "Git", "icon": "empty-window" },
      { "command": "git.deleteWorktree", "title": "Delete Worktree...", "category": "Git", "icon": "remove" },
      { "command": "git.openChange", "title": "Open Changes", "category": "Git" },
      { "command": "git.openMergeEditor", "title": "Resolve in Merge Editor", "category": "Git", "icon": "merge" },
      { "command": "git.openFile", "title": "Open File", "category": "Git" },
      { "command": "git.getCommitDiff", "title": "Get Commit Diff", "category": "Git" },
      { "command": "git.setCommitMessage", "title": "Set Commit Message", "category": "Git" },
      { "command": "git.pull", "title": "Pull", "category": "Git", "icon": "pull" },
      { "command": "git.pullRebase", "title": "Pull (Rebase)", "category": "Git", "icon": "pull" },
      { "command": "git.pullAutostash", "title": "Pull (Autostash)", "category": "Git", "icon": "pull" },
      { "command": "git.push", "title": "Push", "category": "Git", "icon": "push" },
      { "command": "git.pushForce", "title": "Push (Force)", "category": "Git", "icon": "push" },
      { "command": "git.pushTo", "title": "Push to...", "category": "Git", "icon": "push" },
      { "command": "git.sync", "title": "Sync (Pull & Push)", "category": "Git", "icon": "sync" },
      { "command": "git.fetch", "title": "Fetch", "category": "Git", "icon": "fetch" },
      { "command": "git.fetchPrune", "title": "Fetch (Prune)", "category": "Git", "icon": "fetch" },
      { "command": "git.stash", "title": "Stash", "category": "Git", "icon": "stash" },
      { "command": "git.stashIncludeUntracked", "title": "Stash (Include Untracked)", "category": "Git", "icon": "stash" },
      { "command": "git.stashApply", "title": "Apply Stash...", "category": "Git", "icon": "stash" },
      { "command": "git.stashPop", "title": "Pop Stash...", "category": "Git", "icon": "stash" },
      { "command": "git.stashDrop", "title": "Drop Stash...", "category": "Git", "icon": "stash" },
      { "command": "git.addRemote", "title": "Add Remote...", "category": "Git", "icon": "remote" },
      { "command": "git.removeRemote", "title": "Remove Remote...", "category": "Git", "icon": "remote" },
      { "command": "git.createTag", "title": "Create Tag...", "category": "Git", "icon": "tag" },
      { "command": "git.deleteTag", "title": "Delete Tag...", "category": "Git", "icon": "tag" },
      { "command": "git.submoduleUpdateInit", "title": "Update Submodules", "category": "Git", "icon": "git-submodule" },
      { "command": "git.submoduleSync", "title": "Sync Submodule URLs", "category": "Git", "icon": "git-submodule" },
      { "command": "git.blame.toggleEditorDecoration", "title": "Toggle Git Blame Editor Decoration", "category": "Git" },
      { "command": "git.blame.toggleStatusBarItem", "title": "Toggle Git Blame Status Bar Item", "category": "Git" }
    ],
    "submenus": [
      { "id": "git.commitMenu", "label": "Commit", "icon": "git-commit" },
      { "id": "git.changesMenu", "label": "Changes", "icon": "stage-all" },
      { "id": "git.pullMenu", "label": "Pull", "icon": "pull" },
      { "id": "git.pushMenu", "label": "Push", "icon": "push" },
      { "id": "git.fetchMenu", "label": "Fetch", "icon": "fetch" },
      { "id": "git.branchMenu", "label": "Branch", "icon": "checkout" },
      { "id": "git.worktreeMenu", "label": "Worktree", "icon": "git-worktree" },
      { "id": "git.stashMenu", "label": "Stash", "icon": "stash" },
      { "id": "git.remoteMenu", "label": "Remote", "icon": "remote" },
      { "id": "git.tagsMenu", "label": "Tags", "icon": "tag" },
      { "id": "git.submoduleMenu", "label": "Submodules", "icon": "git-submodule" }
    ],
    "menus": {
      "scm/title": [
        { "command": "git-graph.view", "group": "navigation@1", "icon": "git-graph" },
        { "command": "git.refresh", "group": "navigation@2", "icon": "refresh" },
        { "submenu": "git.commitMenu", "group": "1_commit@1" },
        { "submenu": "git.changesMenu", "group": "2_changes@1" },
        { "submenu": "git.pullMenu", "group": "3_sync@1" },
        { "submenu": "git.pushMenu", "group": "3_sync@2" },
        { "command": "git.sync", "group": "3_sync@3", "icon": "sync" },
        { "submenu": "git.fetchMenu", "group": "3_sync@4" },
        { "submenu": "git.branchMenu", "group": "4_branch@1" },
        { "submenu": "git.worktreeMenu", "group": "4_branch@2" },
        { "submenu": "git.stashMenu", "group": "5_stash@1" },
        { "submenu": "git.remoteMenu", "group": "6_remote@1" },
        { "submenu": "git.tagsMenu", "group": "6_remote@2" },
        { "submenu": "git.submoduleMenu", "group": "7_submodule@1" }
      ],
      "git.commitMenu": [
        { "command": "git.commit", "group": "1@1", "icon": "git-commit" },
        { "command": "git.commitAndPush", "group": "1@2", "icon": "push" },
        { "command": "git.commitAndSync", "group": "1@3", "icon": "sync" },
        { "command": "git.undoLastCommit", "group": "2@1", "icon": "discard" }
      ],
      "git.changesMenu": [
        { "command": "git.stageAll", "group": "1@1", "icon": "stage-all" },
        { "command": "git.unstageAll", "group": "1@2", "icon": "unstage-all" },
        { "command": "git.discardAll", "group": "1@3", "icon": "discard-all" }
      ],
      "git.pullMenu": [
        { "command": "git.pull", "group": "1@1", "icon": "pull" },
        { "command": "git.pullRebase", "group": "1@2", "icon": "pull" },
        { "command": "git.pullAutostash", "group": "1@3", "icon": "pull" }
      ],
      "git.pushMenu": [
        { "command": "git.push", "group": "1@1", "icon": "push" },
        { "command": "git.pushForce", "group": "1@2", "icon": "push" },
        { "command": "git.pushTo", "group": "1@3", "icon": "push" }
      ],
      "git.fetchMenu": [
        { "command": "git.fetch", "group": "1@1", "icon": "fetch" },
        { "command": "git.fetchPrune", "group": "1@2", "icon": "fetch" }
      ],
      "git.branchMenu": [
        { "command": "git.checkout", "group": "1@1", "icon": "checkout" },
        { "command": "git.createBranch", "group": "1@2", "icon": "create-branch" },
        { "command": "git.renameBranch", "group": "1@3", "icon": "checkout" },
        { "command": "git.deleteBranch", "group": "1@4", "icon": "remove" },
        { "command": "git.merge", "group": "2@1", "icon": "merge" },
        { "command": "git.rebase", "group": "2@2", "icon": "merge" },
        { "command": "git.publishBranch", "group": "3@1", "icon": "push" }
      ],
      "git.worktreeMenu": [
        { "command": "git.createWorktree", "group": "1@1", "icon": "new-folder" },
        { "command": "git.openWorktree", "group": "2@1", "icon": "git-worktree" },
        { "command": "git.openWorktreeInNewWindow", "group": "2@2", "icon": "empty-window" },
        { "command": "git.deleteWorktree", "group": "3@1", "icon": "remove" }
      ],
      "git.stashMenu": [
        { "command": "git.stash", "group": "1@1", "icon": "stash" },
        { "command": "git.stashIncludeUntracked", "group": "1@2", "icon": "stash" },
        { "command": "git.stashApply", "group": "2@1", "icon": "stash" },
        { "command": "git.stashPop", "group": "2@2", "icon": "stash" },
        { "command": "git.stashDrop", "group": "2@3", "icon": "stash" }
      ],
      "git.remoteMenu": [
        { "command": "git.addRemote", "group": "1@1", "icon": "remote" },
        { "command": "git.removeRemote", "group": "1@2", "icon": "remote" }
      ],
      "git.tagsMenu": [
        { "command": "git.createTag", "group": "1@1", "icon": "tag" },
        { "command": "git.deleteTag", "group": "1@2", "icon": "tag" }
      ],
      "git.submoduleMenu": [
        { "command": "git.submoduleUpdateInit", "group": "1@1", "icon": "git-submodule" },
        { "command": "git.submoduleSync",       "group": "1@2", "icon": "git-submodule" }
      ],
      "scm/resourceState/context": [
        { "command": "git.openMergeEditor", "when": "scmResourceState == U", "group": "inline", "icon": "merge" },
        { "command": "git.stage", "when": "scmResourceGroup == workingTree", "group": "inline", "icon": "add" },
        { "command": "git.discard", "when": "scmResourceGroup == workingTree", "group": "inline", "icon": "discard" },
        { "command": "git.unstage", "when": "scmResourceGroup == index", "group": "inline", "icon": "remove" }
      ],
      "scm/resourceGroup/context": [
        { "command": "git.stageAll", "when": "scmResourceGroup == workingTree", "group": "inline", "icon": "stage-all" },
        { "command": "git.discardAll", "when": "scmResourceGroup == workingTree", "group": "inline", "icon": "discard-all" },
        { "command": "git.unstageAll", "when": "scmResourceGroup == index", "group": "inline", "icon": "unstage-all" }
      ]
    },
    "keybindings": [
      {
        "command": "git.refresh",
        "key": "ctrl+alt+g"
      },
      {
        "command": "git.openChange",
        "key": "shift+alt+y",
        "when": "!isInDiffEditor"
      },
      {
        "command": "git.openFile",
        "key": "shift+alt+y",
        "when": "isInDiffEditor"
      }
    ],
    "configuration": {
      "title": "Git",
      "properties": {
        "git.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether git source control is enabled."
        },
        "git.mergeEditor": {
          "type": "boolean",
          "default": true,
          "description": "Open conflicted files in the 3-way merge editor. When false, conflicts open as a working-tree diff and are resolved inline via conflict markers."
        },
        "git.autoRepositoryDetection": {
          "type": "boolean",
          "default": true,
          "description": "Scan workspace subfolders for nested git repositories. When false, only the workspace root is used."
        },
        "git.repositoryScanMaxDepth": {
          "type": "number",
          "default": 3,
          "minimum": -1,
          "description": "Maximum subfolder depth to scan for nested git repositories. -1 means unlimited."
        },
        "git.repositoryScanIgnoredFolders": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["node_modules"],
          "description": "Folder names skipped while scanning for nested git repositories."
        },
        "git.pullSubmoduleUpdate": {
          "type": "boolean",
          "default": true,
          "description": "After a successful pull, automatically run `git submodule update --init --recursive` when the repository contains submodules."
        },
        "git.autofetch": {
          "type": "boolean",
          "default": true,
          "description": "Periodically fetch from the remote so the status bar shows incoming/outgoing commits."
        },
        "git.autofetchPeriod": {
          "type": "number",
          "default": 180,
          "minimum": 30,
          "description": "Interval (in seconds) between automatic fetches when git.autofetch is enabled."
        },
        "git.blame.editorDecoration.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the blame information for the line the cursor is on at the end of the line."
        },
        "git.blame.editorDecoration.template": {
          "type": "string",
          "default": "${subject}, ${authorName} (${authorDateAgo})",
          "description": "Template for the inline blame annotation. Tokens: ${hash}, ${hashShort}, ${subject}, ${authorName}, ${authorEmail}, ${authorDate}, ${authorDateAgo}."
        },
        "git.blame.editorDecoration.disableHover": {
          "type": "boolean",
          "default": false,
          "description": "Disable the hover that shows full commit info when pointing at the inline blame annotation."
        },
        "git.blame.statusBarItem.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the blame information for the line the cursor is on in the status bar."
        },
        "git.blame.statusBarItem.template": {
          "type": "string",
          "default": "${authorName} (${authorDateAgo})",
          "description": "Template for the blame information status bar item. Tokens: ${hash}, ${hashShort}, ${subject}, ${authorName}, ${authorEmail}, ${authorDate}, ${authorDateAgo}."
        },
        "git.blame.ignoreWhitespace": {
          "type": "boolean",
          "default": false,
          "description": "Ignore whitespace changes when computing blame information."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@universe-editor/config-ts": "workspace:*",
    "@universe-editor/extension-api": "workspace:*",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
