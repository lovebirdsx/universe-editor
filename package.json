{
  "name": "@universe-editor/root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e": "pnpm build && pnpm --filter @universe-editor/editor e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check": "pnpm docs:check && turbo run lint typecheck test",
    "docs:check": "node scripts/check-doc-links.mjs",
    "check:full": "pnpm docs:check && turbo run lint typecheck test build",
    "dev": "pnpm --filter=@universe-editor/editor dev",
    "memory:link": "node scripts/link-memory.mjs",
    "memory:status": "node scripts/link-memory.mjs --status",
    "skills:policy": "node scripts/sync-codex-skill-policy.mjs",
    "skills:policy:check": "node scripts/sync-codex-skill-policy.mjs --check",
    "bundle-size": "node scripts/bench/bundle-size.mjs",
    "bundle-size:update": "node scripts/bench/bundle-size.mjs --update",
    "agent:build": "node scripts/release/vendor-install.mjs && npm --prefix vendor/claude-agent-acp run build && npm --prefix vendor/codex-acp run build",
    "ext:build": "turbo run build --filter=@universe-editor/extension-host --filter=\"./extensions/*\"",
    "runtime:stage": "pnpm -w run agent:build && pnpm -w run ext:build && node scripts/release/runtime-resources.mjs stage",
    "runtime:verify:source": "node scripts/release/runtime-resources.mjs verify-source",
    "runtime:verify:packaged": "node scripts/release/runtime-resources.mjs verify-packaged",
    "clean": "git clean -fdx -e .claude -e apps/editor/release",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "release": "node scripts/release/release.mjs",
    "release:upload": "node scripts/release/upload.mjs",
    "release:notes": "node scripts/release/changelog.mjs",
    "test:release": "node --test \"scripts/**/__tests__/**/*.test.mjs\"",
    "server:serve": "node scripts/server/server.mjs --root apps/editor/release --port 8788 --base /"
  },
  "devDependencies": {
    "@universe-editor/config-eslint": "workspace:*",
    "@changesets/cli": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
