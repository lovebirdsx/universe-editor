{
  "name": "@universe-editor/root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e": "pnpm build && pnpm --filter @universe-editor/editor e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check": "turbo run lint typecheck test",
    "check:full": "turbo run lint typecheck test build",
    "dev": "pnpm --filter @universe-editor/editor dev",
    "agent:build": "npm --prefix vendor/claude-agent-acp ci && npm --prefix vendor/claude-agent-acp run build",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "release": "node scripts/release/release.mjs",
    "release:upload": "node scripts/release/upload.mjs",
    "release:notes": "node scripts/release/changelog.mjs",
    "test:release": "node --test \"scripts/release/__tests__/**/*.test.mjs\"",
    "server:serve": "node scripts/server/server.mjs --root apps/editor/release --port 8788 --base /"
  },
  "devDependencies": {
    "@universe-editor/config-eslint": "workspace:*",
    "@changesets/cli": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
