{
  "name": "@universe-editor/root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e": "pnpm build && pnpm --filter @universe-editor/editor e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check": "turbo run lint typecheck test",
    "check:full": "turbo run lint typecheck test build",
    "dev": "pnpm --filter=@universe-editor/editor dev",
    "agent:build": "node scripts/release/agent-install.mjs && npm --prefix vendor/claude-agent-acp run build",
    "ext:build": "turbo run build --filter=@universe-editor/extension-host --filter=\"./extensions/*\"",
    "runtime:stage": "pnpm -w run agent:build && pnpm -w run ext:build && node scripts/release/runtime-resources.mjs stage",
    "runtime:verify:source": "node scripts/release/runtime-resources.mjs verify-source",
    "runtime:verify:packaged": "node scripts/release/runtime-resources.mjs verify-packaged",
    "clean": "git clean -fdx -e .claude -e apps/editor/release",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "release": "node scripts/release/release.mjs",
    "release:upload": "node scripts/release/upload.mjs",
    "release:notes": "node scripts/release/changelog.mjs",
    "test:release": "node --test \"scripts/**/__tests__/**/*.test.mjs\"",
    "server:serve": "node scripts/server/server.mjs --root apps/editor/release --port 8788 --base /"
  },
  "devDependencies": {
    "@universe-editor/config-eslint": "workspace:*",
    "@changesets/cli": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
