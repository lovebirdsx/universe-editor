{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "//": "typecheck dependsOn ^typecheck (not ^build): tsc --build + project references self-build upstream .d.ts. build.outputs lists *.tsbuildinfo so cache hits restore tsc incremental state.",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "!src/**/__tests__/**",
        "!src/**/*.test.ts",
        "!src/**/*.test.tsx",
        "package.json",
        "tsconfig*.json"
      ],
      "outputs": ["dist/**", "out/**", "*.tsbuildinfo"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "e2e": {
      "dependsOn": ["^build", "build"],
      "outputs": ["e2e/playwright-report/**", "e2e/test-results/**"],
      "env": ["CI", "UNIVERSE_E2E"]
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
